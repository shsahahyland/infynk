# ─────────────────────────────────────────────────────────────────────────────
# infynk — environment variable template
# Copy this file to .env and fill in your real secrets.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI – Groq (free tier) ────────────────────────────────────────────────────
# Sign up free at https://console.groq.com → API Keys
# Free tier: 14,400 requests/day on Llama 3.3 70B
GROQ_API_KEY=gsk_...

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token (PAT) with read:repo scope
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ── Confluence (Atlassian Cloud) ──────────────────────────────────────────────
# The email address tied to your Atlassian account
CONFLUENCE_EMAIL=you@company.com
# API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_TOKEN=

# ── Jira (Atlassian Cloud) ────────────────────────────────────────────────────
# The email address tied to your Atlassian account (often the same as above)
JIRA_EMAIL=you@company.com
# API token — same token as Confluence works for both Jira and Confluence
JIRA_TOKEN=

# ── Hyland Docs connector (no token needed — public site) ───────────────────
# Set to "true" to enable scraping of support.hyland.com documentation pages
HYLAND_DOCS_ENABLED=true

# ── Teams Bot (optional — only needed if running the Teams integration) ───────
# URL where the FastAPI backend is reachable from the bot process
INFYNK_API_URL=http://localhost:8000
# Port the Express bot server listens on
BOT_PORT=3978
